# Root-level env used by `pnpm db:migrate`. Per-service envs live in
# apps/<service>/.env.example with their own values.

DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# PND treasury: receives the FixedPriceMinter referral share on mints made
# through this site. Unset = zero address = the full share accrues to the artist.
NEXT_PUBLIC_PND_REFERRAL_ADDRESS=0xea194A186EBe76A84E2B2027f5f23F81939c05AD
