# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# Used by /api/rpc proxy (server-side only — never NEXT_PUBLIC_)
ALCHEMY_API_KEY=

# RainbowKit/WalletConnect handshake
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Ponder schema name (matches DATABASE_SCHEMA on the indexer service)
INDEXER_SCHEMA=ponder_v1

# Worker URL — web app forwards "Refresh my work" to the worker via this
WORKER_URL=http://localhost:8080
WORKER_SECRET=

# Cache invalidation secret (used by /api/revalidate, /api/seller-listings/revalidate, etc.)
REVALIDATE_SECRET=

# Collection referral share recipient: the address PND passes as `referrer`
# on mints hosted by this app (10% of the price accrues to it, pull-payment).
# Unset = zero address = the share folds back to the artist and PND earns
# nothing. Use a long-lived treasury (mutable 0xSplits / Safe) — accrued
# balances are forever tied to the exact address they were earned under.
# (Legacy name NEXT_PUBLIC_PND_SURFACE_ADDRESS is still read as a fallback.)
NEXT_PUBLIC_PND_REFERRAL_ADDRESS=

# Kill switches
INDEXER_DISABLED=

# Homage to the Punk mainnet launch flip (unset = pre-deploy static shadow
# page at /collections/homage). Set all three together. Also requires editing
# the MAINNET_HOMAGE const in apps/web/src/lib/homage/registry.ts, see the
# "Homage mainnet env flip" subsection in docs/pnd-surface-prelaunch.md.
NEXT_PUBLIC_HOMAGE_COLLECTION_ADDRESS=
NEXT_PUBLIC_HOMAGE_MINTER_ADDRESS=
NEXT_PUBLIC_HOMAGE_RENDERER=
