# Mainnet RPC endpoint. Provider-neutral — point at any JSON-RPC
# compatible endpoint (Alchemy, Quicknode, drpc, a self-hosted node).
# Server-side ONLY. Never use NEXT_PUBLIC_ prefix on a URL containing
# credentials — Next.js inlines NEXT_PUBLIC_* values into the client JS
# bundle at build time, which would let any visitor scrape the key.
# Browser RPC goes through /api/rpc (server-side proxy that uses
# MAINNET_RPC_URL as its primary upstream).
MAINNET_RPC_URL=https://your-provider.example/your-key

# Optional: Alchemy API key for Alchemy's enhanced NFT API. Required ONLY
# for: Manifold artist + collector token discovery (via /nft/v3/), Foundation
# and SuperRare collector views (via getNFTsForOwner), and ERC-1155 token
# supporter / holder stats (via alchemy_getAssetTransfers). Without this
# key, those features return empty results but the rest of the app works
# (artist pages for Foundation/SuperRare/Sovereign/Transient, auctions,
# listings, Sovereign deploys, the RPC proxy itself).
# Server-side only — no NEXT_PUBLIC_ prefix.
# ALCHEMY_API_KEY=YOUR_KEY

# Optional: secondary RPC fallback used by the /api/rpc proxy. Useful as
# an authenticated backup when the primary upstream is rate-limited or
# down. Infura's free tier restricts eth_getLogs to a 10-block range;
# the proxy detects that response and falls through to a public RPC.
# INFURA_API_KEY=YOUR_KEY

# Optional: dev-only flag for running against a local Anvil mainnet fork.
# Set to "1" alongside an ANVIL_RPC_URL to flip wagmi's preferred chain to
# foundry (31337) so wallet writes hit the fork, not real mainnet. Leave
# unset (or set to "0") in production.
# NEXT_PUBLIC_USE_LOCAL_RPC=1

# Emergency RPC kill switch. Set to "1" to short-circuit the four most
# expensive server-side fetchers (token transfer history, last-sale ×2,
# artist token discovery). Pages fall back to whatever's in pgCache;
# bid panel + /api/rpc proxy stay operational so bidders can still bid.
# Use when the Alchemy bill is bleeding faster than you can patch
# individual call sites. Unset (or "0") in normal operation.
# RPC_DISABLED=1

# WalletConnect project ID (get one free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Optional: Ponder indexer URL (for enhanced token detail pages)
# PONDER_URL=http://localhost:42069
# NEXT_PUBLIC_PONDER_URL=http://localhost:42069

# Optional: Etherscan API key (free at https://etherscan.io/apis).
# Enables Manifold Creator Core discovery in the artist gallery — without it,
# Manifold-deployed tokens won't appear (Foundation tokens still load fine).
# Server-side only — no NEXT_PUBLIC_ prefix.
# ETHERSCAN_API_KEY=YOUR_KEY

# Site URL (for metadata/OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible Analytics. Set to the site domain configured in Plausible
# (e.g. "jollywave.xyz"). When unset, the script tag is not rendered, so
# previews / local dev don't pollute the dashboard.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jollywave.xyz

# RPC event log salt + sample rate. RPC_LOG_SALT is required for
# per-IP visibility (hashIp returns null without it; aggregate counts
# still work). RPC_LOG_SAMPLE is the fraction of RPC calls written to
# the rpc_events table — defaults to 0.1 (10 %). Multiply aggregate
# counts by 1/sample to estimate true volume.
# RPC_LOG_SALT=
# RPC_LOG_SAMPLE=0.1
