# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# Paid Alchemy is the right call for worker scans — volume bounded by
# known_artists × cadence, not by user traffic.
ALCHEMY_API_KEY=
# Or set the full URL explicitly:
# ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/...

# Etherscan API key (Manifold scanner needs txlist)
ETHERSCAN_API_KEY=

# Auth for POST /jobs/refresh-artist — must match web app's WORKER_SECRET
REVALIDATE_SECRET=

# Tuning
WARMER_BATCH_SIZE=50
WARMER_CONCURRENCY=4
WARMER_RETRY_AFTER=7 days

# Server port (Railway assigns automatically)
PORT=8080
