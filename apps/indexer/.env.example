# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres
DATABASE_SCHEMA=ponder_v1

# drpc.org free tier handles Ponder's factory-pattern multi-address
# eth_getLogs correctly. publicnode / llamarpc / ankr / Alchemy do not
# (or burn CU; see ../README.md "RPC strategy").
PONDER_RPC_URL_1=https://eth.drpc.org

# ── Homage ("Homage to the Punk") — DEPLOY-GATED (optional) ─────────────
# The Homage singleton is registered ONLY when BOTH of these are set. Leave
# them unset until the contract is deployed + the ABI is audit-frozen (Phase
# 0 gate G1); the indexer runs unchanged without them. At launch, set both
# and redeploy Ponder.
#   HOMAGE_ADDRESS      deployed Homage contract (checksummed 0x… address)
#   HOMAGE_START_BLOCK  deploy block (backfill starts here)
# HOMAGE_ADDRESS=0x...
# HOMAGE_START_BLOCK=
