# Required
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres
DATABASE_SCHEMA=ponder_v1

# drpc.org free tier handles Ponder's factory-pattern multi-address
# eth_getLogs correctly. publicnode / llamarpc / ankr / Alchemy do not
# (or burn CU; see ../README.md "RPC strategy").
PONDER_RPC_URL_1=https://eth.drpc.org

# ── Homage ("Homage to the Punk") — DEPLOY-GATED (optional) ─────────────
# Homage is the sovereign two-contract shape: HomageMinter (mint/economics)
# + HomageCollection (the pooled ERC721 token). Both pairs are registered
# ONLY when ALL FOUR of these are set (gated atomically). Leave them unset
# until the contracts are deployed + the ABIs are audit-frozen (Phase 0 gate
# G1); the indexer runs unchanged without them. At launch, set all four and
# redeploy Ponder.
#   HOMAGE_MINTER_ADDRESS          deployed HomageMinter contract (checksummed 0x… address)
#   HOMAGE_MINTER_START_BLOCK      HomageMinter deploy block (backfill starts here)
#   HOMAGE_COLLECTION_ADDRESS      deployed pooled Collection contract (checksummed 0x… address)
#   HOMAGE_COLLECTION_START_BLOCK  Collection deploy block (backfill starts here)
# HOMAGE_MINTER_ADDRESS=0x...
# HOMAGE_MINTER_START_BLOCK=
# HOMAGE_COLLECTION_ADDRESS=0x...
# HOMAGE_COLLECTION_START_BLOCK=
