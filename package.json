{
  "name": "pnd-v2",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev:web": "pnpm --filter @pin/web dev",
    "dev:indexer": "pnpm --filter @pin/indexer dev",
    "dev:worker": "pnpm --filter @pin/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "node --env-file=.env db/migrate.mjs",
    "worker:refresh": "node --env-file=.env scripts/worker-refresh.mjs"
  },
  "devDependencies": {
    "postgres": "^3.4.9",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
