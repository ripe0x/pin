# ─── Required ──────────────────────────────────────────────────────────────

# Your Ethereum wallet address. The page surfaces every auction this wallet
# has on supported marketplaces.
NEXT_PUBLIC_ARTIST_ADDRESS=0x0000000000000000000000000000000000000000


# ─── Recommended (but optional) ────────────────────────────────────────────

# Your own RPC URL (Alchemy, Infura, etc). Makes the page noticeably faster.
# Leave blank to use the bundled public RPC defaults.
NEXT_PUBLIC_RPC_URL=


# ─── Customize (everything below is optional) ──────────────────────────────
#
# Each of these defaults to your ENS profile if you have one. Set these env
# vars only if you want to override the ENS-derived values.

# Display name. Default: ENS reverse-resolution → truncated address.
NEXT_PUBLIC_ARTIST_NAME=

# Square avatar URL. Default: ENS `avatar` text record → address-derived
# gradient.
NEXT_PUBLIC_ARTIST_AVATAR_URL=

# Short bio. Default: ENS `description` text record → empty.
NEXT_PUBLIC_ARTIST_BIO=

# Comma-separated social URLs. Default: ENS `url`, `com.twitter`,
# `org.farcaster`, `com.github` text records → empty.
NEXT_PUBLIC_ARTIST_LINKS=

# Comma-separated list of RPC URLs if you want to specify your own
# failover chain. Overrides NEXT_PUBLIC_RPC_URL when set.
NEXT_PUBLIC_RPC_URLS=

# Your deployed SovereignCollection address, if you have one. Adds a mint
# card + recent-mints grid to the page. Leave blank and the page stays
# auction-only with no visible change.
NEXT_PUBLIC_COLLECTION_ADDRESS=

# Public site URL (e.g. https://yoursite.com), used to build absolute
# social-card (OpenGraph / Twitter) image links. On Netlify and Vercel this
# is auto-detected from their build env vars — only set it if you use a
# custom domain those vars don't already report.
NEXT_PUBLIC_SITE_URL=

# Secret that protects POST /api/revalidate. Token metadata is cached for 24h;
# set this to any random string to enable on-demand refreshes when a token's
# metadata changes (reveal, corrected data, swapped media). Leave blank to
# disable the endpoint entirely. NOT a NEXT_PUBLIC_ var — keep it server-side.
#   Refresh one token:  curl -X POST ".../api/revalidate?token=0xCONTRACT:ID" -H "x-revalidate-secret: <secret>"
#   Refresh everything: curl -X POST ".../api/revalidate"                      -H "x-revalidate-secret: <secret>"
REVALIDATE_SECRET=

# Optional. Set this to enable WalletConnect mobile QR connections
# (Rainbow mobile, Trust, MetaMask Mobile, etc). Free + takes 2 min:
# register at https://cloud.reown.com, copy the project ID, paste here.
# Without this, the connect modal still shows MetaMask, Rabby, Coinbase
# Wallet, Safe, and other browser-extension wallets — that's the default
# zero-config experience.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
