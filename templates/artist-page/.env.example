# ─── Required ──────────────────────────────────────────────────────────────

# Your Ethereum wallet address. The page surfaces every auction this wallet
# has on supported marketplaces.
NEXT_PUBLIC_ARTIST_ADDRESS=0x0000000000000000000000000000000000000000


# ─── Recommended (but optional) ────────────────────────────────────────────

# Your own RPC URL (Alchemy, Infura, etc). Makes the page noticeably faster.
# Leave blank to use the bundled public RPC defaults.
NEXT_PUBLIC_RPC_URL=


# ─── Customize (everything below is optional) ──────────────────────────────
#
# Each of these defaults to your ENS profile if you have one. Set these env
# vars only if you want to override the ENS-derived values.

# Display name. Default: ENS reverse-resolution → truncated address.
NEXT_PUBLIC_ARTIST_NAME=

# Square avatar URL. Default: ENS `avatar` text record → address-derived
# gradient.
NEXT_PUBLIC_ARTIST_AVATAR_URL=

# Short bio. Default: ENS `description` text record → empty.
NEXT_PUBLIC_ARTIST_BIO=

# Comma-separated social URLs. Default: ENS `url`, `com.twitter`,
# `org.farcaster`, `com.github` text records → empty.
NEXT_PUBLIC_ARTIST_LINKS=

# Comma-separated list of RPC URLs if you want to specify your own
# failover chain. Overrides NEXT_PUBLIC_RPC_URL when set.
NEXT_PUBLIC_RPC_URLS=

# WalletConnect project ID. A shared template ID is bundled, so you only
# need this if you're seeing rate-limit errors.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
