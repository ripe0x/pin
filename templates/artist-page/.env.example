# Required: the artist's wallet address. The page resolves their auction
# house automatically via the SovereignAuctionHouseFactory.houseOf(...) call.
NEXT_PUBLIC_ARTIST_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: how to display the artist's name across the page + link unfurls.
# If unset, the page uses the ENS reverse-resolution of NEXT_PUBLIC_ARTIST_ADDRESS
# (e.g. "vitalik.eth"). Falls back to a truncated address if there's no ENS
# primary name set on the wallet.
NEXT_PUBLIC_ARTIST_NAME=

# Optional: a square avatar URL. Used in the header + OG previews.
NEXT_PUBLIC_ARTIST_AVATAR_URL=

# Optional: short bio shown under the artist name on the index page.
NEXT_PUBLIC_ARTIST_BIO=

# Optional: comma-separated social URLs ("https://twitter.com/...,https://...").
NEXT_PUBLIC_ARTIST_LINKS=

# Optional: your own RPC URL (Alchemy/Infura/QuickNode/etc). When set, this
# becomes the primary endpoint and the public RPCs become fallbacks. Leave
# empty to use the bundled public RPC failover chain (PublicNode → drpc →
# LlamaRPC → Cloudflare). Add this if traffic justifies it.
NEXT_PUBLIC_RPC_URL=

# Optional: comma-separated list of RPC URLs if you want to specify your own
# failover chain. Overrides NEXT_PUBLIC_RPC_URL when set.
NEXT_PUBLIC_RPC_URLS=

# Optional: WalletConnect project ID. A shared template ID is bundled, so
# you only need this if you're seeing rate-limit errors.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
